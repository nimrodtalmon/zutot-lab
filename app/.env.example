# Copy to .env.local and fill in.
VITE_GOOGLE_CLIENT_ID=YOUR_GOOGLE_OAUTH_CLIENT_ID.apps.googleusercontent.com
# Google's "Web application" client type requires the secret on token exchange
# even when using PKCE. Anyone with the deployed bundle can read this value.
# For a single-user, test-mode app this is acceptable.
VITE_GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_OAUTH_CLIENT_SECRET
